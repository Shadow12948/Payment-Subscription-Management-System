func HandleWebhook(w http.ResponseWriter, r *http.Request, db *sql.DB) {
    var event struct {
        ID   string `json:"id"`
        Type string `json:"type"`
    }

    json.NewDecoder(r.Body).Decode(&event)

    _, err := db.Exec("INSERT INTO webhook_events(id, type, processed) VALUES($1,$2,false)", event.ID, event.Type)
    if err != nil {
        // already processed
        w.WriteHeader(http.StatusOK)
        return
    }

    switch event.Type {
    case "payment.success":
        // update invoice
    }

    db.Exec("UPDATE webhook_events SET processed=true WHERE id=$1", event.ID)

    w.WriteHeader(http.StatusOK)
}

