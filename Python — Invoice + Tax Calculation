from datetime import datetime, timedelta
from uuid import uuid4
from .tax import calculate_tax

def generate_invoice(user_id, subscription_id, amount_cents, currency, country):
    tax = calculate_tax(amount_cents, country)
    total = amount_cents + tax

    invoice = {
        "id": str(uuid4()),
        "user_id": user_id,
        "subscription_id": subscription_id,
        "amount_cents": total,
        "currency": currency,
        "tax_cents": tax,
        "status": "pending",
        "due_date": datetime.utcnow() + timedelta(days=7)
    }

    return invoice
