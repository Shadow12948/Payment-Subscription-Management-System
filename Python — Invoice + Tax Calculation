def calculate_tax(amount_cents: int, country: str) -> int:
    tax_rates = {
        "US": 0.07,
        "DE": 0.19,
        "IN": 0.18
    }
    rate = tax_rates.get(country, 0.0)
    return int(amount_cents * rate)

